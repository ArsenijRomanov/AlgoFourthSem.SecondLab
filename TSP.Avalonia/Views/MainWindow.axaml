<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:TSP.Avalonia.ViewModels"
        xmlns:controls="using:TSP.Avalonia.Controls"
        x:Class="TSP.Avalonia.Views.MainWindow"
        mc:Ignorable="d"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        MinWidth="1100"
        MinHeight="760"
        Title="Задача коммивояжёра">
  <Design.DataContext>
    <vm:MainWindowViewModel />
  </Design.DataContext>

  <Grid Margin="16"
        RowDefinitions="*,Auto"
        ColumnDefinitions="380,*"
        ColumnSpacing="16"
        RowSpacing="12">

    <ScrollViewer Grid.Row="0"
                  Grid.Column="0"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  AllowAutoHide="False">
      <StackPanel Spacing="0">
        <Border Classes="card">
          <StackPanel Spacing="10">
            <TextBlock Classes="panel-title" Text="Источник графа" />

            <TextBlock Classes="field-label" Text="Встроенный пример" />

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
              <ComboBox ItemsSource="{Binding ExampleOptions}"
                        SelectedItem="{Binding SelectedExample}" />

              <Button Grid.Column="1"
                      Classes="action"
                      Command="{Binding LoadExampleCommand}"
                      Content="Загрузить" />
            </Grid>

            <Button Classes="action"
                    Content="Выбрать STP-файл..."
                    Click="BrowseGraphClick" />

            <Border Classes="surface-card">
              <StackPanel Spacing="4">
                <TextBlock FontSize="16"
                           FontWeight="SemiBold"
                           Text="{Binding GraphTitle}" />
                <TextBlock Classes="muted"
                           Text="{Binding GraphSummary}"
                           TextWrapping="Wrap" />
              </StackPanel>
            </Border>
          </StackPanel>
        </Border>

        <Border Classes="card">
          <StackPanel Spacing="10">
            <TextBlock Classes="panel-title" Text="Конфигурация" />

            <StackPanel>
              <TextBlock Classes="field-label" Text="Алгоритм" />
              <ComboBox ItemsSource="{Binding AlgorithmOptions}"
                        SelectedItem="{Binding SelectedAlgorithm}" />
            </StackPanel>

            <StackPanel IsVisible="{Binding IsSimulatedAnnealing}">
              <TextBlock Classes="field-label" Text="Вариант имитации отжига" />
              <ComboBox ItemsSource="{Binding CoolingKindOptions}"
                        SelectedItem="{Binding SelectedCoolingKind}" />
            </StackPanel>

            <StackPanel IsVisible="{Binding IsSimulatedAnnealing}" Spacing="8">
              <CheckBox Content="Автоматический расчёт начальной температуры"
                        IsChecked="{Binding UseAutomaticInitialTemperature}" />

              <StackPanel IsVisible="{Binding IsManualInitialTemperature}">
                <TextBlock Classes="field-label" Text="Начальная температура" />
                <NumericUpDown Minimum="0.1"
                               Maximum="1000"
                               Increment="0.1"
                               FormatString="0.###"
                               Value="{Binding ManualInitialTemperature}" />
              </StackPanel>
            </StackPanel>

            <StackPanel IsVisible="{Binding IsAntColony}" Spacing="10">
              <StackPanel>
                <TextBlock Classes="field-label" Text="Размер колонии" />
                <NumericUpDown Minimum="1"
                               Maximum="500"
                               Increment="1"
                               Value="{Binding AntCount}" />
              </StackPanel>

              <CheckBox Content="Оптимизация: элитные муравьи"
                        IsChecked="{Binding UseEliteAnts}" />
            </StackPanel>

            <Button Classes="action"
                    Content="Расширенные настройки..."
                    Click="OpenAdvancedSettingsClick" />
          </StackPanel>
        </Border>

        <Border Classes="card">
          <StackPanel Spacing="10">
            <TextBlock Classes="panel-title" Text="Критерии остановки и запуск" />

            <StackPanel>
              <TextBlock Classes="field-label"
                         Text="Максимум итераций для Run"
                         TextWrapping="Wrap" />
              <NumericUpDown Minimum="100"
                             Maximum="100000"
                             Increment="100"
                             Value="{Binding MaxIterations}" />
            </StackPanel>

            <StackPanel>
              <TextBlock Classes="field-label"
                         Text="Шагов по кнопке Step"
                         TextWrapping="Wrap" />
              <NumericUpDown Minimum="1"
                             Maximum="1000"
                             Increment="1"
                             Value="{Binding StepBatchSize}" />
            </StackPanel>

            <CheckBox Content="Остановить при отсутствии улучшений"
                      IsChecked="{Binding UseMaxIterationsWithoutImprovement}" />

            <StackPanel IsVisible="{Binding UseMaxIterationsWithoutImprovement}">
              <TextBlock Classes="field-label"
                         Text="Max iterations without improvement"
                         TextWrapping="Wrap" />
              <NumericUpDown Minimum="20"
                             Maximum="10000"
                             Increment="10"
                             Value="{Binding MaxIterationsWithoutImprovement}" />
            </StackPanel>

            <WrapPanel Margin="0,6,0,0">
              <Button Classes="action"
                      Width="126"
                      Margin="0,0,10,10"
                      Command="{Binding InitializeCommand}"
                      Content="Initialize" />

              <Button Classes="action"
                      Width="126"
                      Margin="0,0,10,10"
                      Command="{Binding StepCommand}"
                      Content="Step" />

              <Button Classes="primary-action"
                      Width="126"
                      Margin="0,0,10,10"
                      Command="{Binding RunCommand}"
                      Content="Run" />

              <Button Classes="action"
                      Width="126"
                      Margin="0,0,10,10"
                      Command="{Binding ResetCommand}"
                      Content="Reset" />
            </WrapPanel>
          </StackPanel>
        </Border>

        <Border Classes="card">
          <StackPanel Spacing="10">
            <TextBlock Classes="panel-title" Text="Визуализация" />

            <CheckBox Content="Показывать номера вершин"
                      IsChecked="{Binding ShowVertexLabels}" />

            <CheckBox Content="Показывать веса рёбер"
                      IsChecked="{Binding ShowWeights}" />

            <CheckBox Content="Показывать направление рёбер"
                      IsChecked="{Binding ShowDirections}" />

            <CheckBox Content="Фиксировать лучший путь"
                      IsChecked="{Binding ShowBestRoutePinned}" />

            <StackPanel IsVisible="{Binding IsAntColony}">
              <TextBlock Classes="field-label" Text="Наложение для ACO" />
              <ComboBox ItemsSource="{Binding AntOverlayOptions}"
                        SelectedItem="{Binding SelectedAntOverlay}" />
            </StackPanel>
          </StackPanel>
        </Border>

        <Border Classes="card">
          <StackPanel Spacing="10">
            <TextBlock Classes="panel-title" Text="Текущий результат" />

            <UniformGrid Columns="2" Rows="3">
              <Border Classes="metric-pill" Margin="0,0,8,8">
                <StackPanel>
                  <TextBlock Classes="muted" Text="Итерации" />
                  <TextBlock Classes="metric-value" Text="{Binding IterationCount}" />
                </StackPanel>
              </Border>

              <Border Classes="metric-pill" Margin="0,0,0,8">
                <StackPanel>
                  <TextBlock Classes="muted" Text="Вычисления ЦФ" />
                  <TextBlock Classes="metric-value" Text="{Binding ObjectiveEvaluations}" />
                </StackPanel>
              </Border>

              <Border Classes="metric-pill" Margin="0,0,8,8">
                <StackPanel>
                  <TextBlock Classes="muted" Text="Лучшее значение" />
                  <TextBlock Classes="metric-value" Text="{Binding BestCostText}" />
                </StackPanel>
              </Border>

              <Border Classes="metric-pill" Margin="0,0,0,8">
                <StackPanel>
                  <TextBlock Classes="muted" Text="Маршрут" />
                  <TextBlock Classes="metric-value" Text="{Binding FeasibleText}" />
                </StackPanel>
              </Border>

              <Border Classes="metric-pill"
                      Margin="0,0,8,0"
                      IsVisible="{Binding IsAntColony}">
                <StackPanel>
                  <TextBlock Classes="muted" Text="Успешные муравьи" />
                  <TextBlock Classes="metric-value" Text="{Binding SuccessfulAnts}" />
                </StackPanel>
              </Border>

              <Border Classes="metric-pill"
                      IsVisible="{Binding IsAntColony}">
                <StackPanel>
                  <TextBlock Classes="muted" Text="Лучшее на итерации" />
                  <TextBlock Classes="metric-value" Text="{Binding IterationBestCostText}" />
                </StackPanel>
              </Border>
            </UniformGrid>

            <Border Classes="surface-card">
              <StackPanel Spacing="6">
                <TextBlock Classes="field-label" Text="Лучший маршрут" />
                <TextBlock Text="{Binding BestRouteText}" TextWrapping="Wrap" />
              </StackPanel>
            </Border>
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>

    <Grid Grid.Row="0"
          Grid.Column="1"
          RowDefinitions="Auto,*">

      <Border Classes="card">
        <StackPanel Spacing="12">
          <StackPanel Spacing="4">
            <TextBlock Classes="panel-title" Text="{Binding GraphTitle}" />
            <TextBlock Classes="muted" Text="{Binding AlgorithmTitle}" />
          </StackPanel>

          <WrapPanel>
            <Button Classes="action"
                    Margin="0,0,10,10"
                    Content="＋"
                    Click="ZoomInPlotClick" />

            <Button Classes="action"
                    Margin="0,0,10,10"
                    Content="－"
                    Click="ZoomOutPlotClick" />

            <Button Classes="action"
                    Margin="0,0,10,10"
                    Content="Сброс масштаба"
                    Click="ResetPlotViewClick" />

            <Button Classes="action"
                    Margin="0,0,10,10"
                    Content="Показать лучший"
                    IsEnabled="{Binding HasBestRoute}"
                    PointerPressed="BestRoutePeekPressed"
                    PointerReleased="BestRoutePeekReleased"
                    PointerCaptureLost="BestRoutePeekCaptureLost" />

            <Button Classes="action"
                    Margin="0,0,10,10"
                    Content="Экспорт PNG"
                    Click="ExportGraphImageClick" />

            <Button Classes="action"
                    Margin="0,0,10,10"
                    Content="Экспорт маршрута"
                    IsEnabled="{Binding HasBestRoute}"
                    Click="ExportRouteClick" />

            <Button Classes="action"
                    Margin="0,0,10,10"
                    Content="График"
                    IsEnabled="{Binding CanShowHistory}"
                    Click="OpenHistoryClick" />
          </WrapPanel>
        </StackPanel>
      </Border>

      <Border Grid.Row="1"
              Classes="surface-card">
        <controls:GraphCanvasControl x:Name="GraphCanvas"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Stretch"
                                     GraphData="{Binding LoadedGraph}"
                                     CurrentRoute="{Binding CurrentRoute}"
                                     BestRoute="{Binding BestRoute}"
                                     SelectedAntRoute="{Binding SelectedAntRoute}"
                                     AntRoutes="{Binding LastBuiltRoutes}"
                                     Pheromones="{Binding Pheromones}"
                                     ShowWeights="{Binding ShowWeights}"
                                     ShowVertexLabels="{Binding ShowVertexLabels}"
                                     ShowDirections="{Binding ShowDirections}"
                                     ShowBestRoute="{Binding ShouldShowBestRoute}"
                                     AntOverlayMode="{Binding SelectedAntOverlay.Value}" />
      </Border>
    </Grid>

    <Expander Grid.Row="1"
              Grid.Column="1"
              Classes="bottom-panel"
              IsVisible="{Binding IsAntColony}"
              Header="Маршруты муравьёв последней итерации"
              IsExpanded="False">
      <Border Classes="surface-card">
        <DataGrid AutoGenerateColumns="False"
                  ItemsSource="{Binding AntRouteRows}"
                  SelectedItem="{Binding SelectedAntRouteRow}"
                  MinHeight="190"
                  CanUserResizeColumns="True">
          <DataGrid.Columns>
            <DataGridTextColumn Header="#" Binding="{Binding Rank}" Width="70" />
            <DataGridTextColumn Header="Стоимость" Binding="{Binding CostText}" Width="120" />
            <DataGridTextColumn Header="Статус" Binding="{Binding FeasibilityText}" Width="130" />
            <DataGridTextColumn Header="Построение" Binding="{Binding CompletionText}" Width="140" />
            <DataGridTextColumn Header="Маршрут" Binding="{Binding RouteText}" Width="*" />
          </DataGrid.Columns>
        </DataGrid>
      </Border>
    </Expander>
  </Grid>
</Window>