<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:TSP.Avalonia.ViewModels"
        x:Class="TSP.Avalonia.Views.AdvancedSettingsWindow"
        Width="560"
        Height="500"
        MinWidth="520"
        MinHeight="420"
        Title="Расширенные настройки"
        mc:Ignorable="d">
  <Design.DataContext>
    <vm:MainWindowViewModel />
  </Design.DataContext>

  <ScrollViewer Margin="16" VerticalScrollBarVisibility="Auto">
    <StackPanel Spacing="0">
      <Border Classes="card" IsVisible="{Binding IsSimulatedAnnealing}">
        <StackPanel Spacing="14">
          <TextBlock Classes="panel-title" Text="Расширенные настройки SA" />

          <StackPanel Spacing="6">
            <TextBlock Classes="field-label" Text="Target acceptance probability" />
            <Grid ColumnDefinitions="*,64" ColumnSpacing="12">
              <Slider Minimum="0.01"
                      Maximum="0.95"
                      Value="{Binding TargetAcceptanceProbability}" />
              <TextBlock Grid.Column="1"
                         VerticalAlignment="Center"
                         HorizontalAlignment="Right"
                         Text="{Binding TargetAcceptanceProbability, StringFormat={}{0:F2}}" />
            </Grid>
          </StackPanel>

          <StackPanel Spacing="6">
            <TextBlock Classes="field-label" Text="Geometric alpha" />
            <Grid ColumnDefinitions="*,64" ColumnSpacing="12">
              <Slider Minimum="0.80"
                      Maximum="0.99"
                      Value="{Binding GeometricAlpha}" />
              <TextBlock Grid.Column="1"
                         VerticalAlignment="Center"
                         HorizontalAlignment="Right"
                         Text="{Binding GeometricAlpha, StringFormat={}{0:F2}}" />
            </Grid>
          </StackPanel>
        </StackPanel>
      </Border>

      <Border Classes="card" IsVisible="{Binding IsAntColony}">
        <StackPanel Spacing="14">
          <TextBlock Classes="panel-title" Text="Расширенные настройки ACO" />

          <StackPanel Spacing="6">
            <TextBlock Classes="field-label" Text="Alpha" />
            <Grid ColumnDefinitions="*,64" ColumnSpacing="12">
              <Slider Minimum="0.1" Maximum="10" Value="{Binding Alpha}" />
              <TextBlock Grid.Column="1"
                         VerticalAlignment="Center"
                         HorizontalAlignment="Right"
                         Text="{Binding Alpha, StringFormat={}{0:F1}}" />
            </Grid>
          </StackPanel>

          <StackPanel Spacing="6">
            <TextBlock Classes="field-label" Text="Beta" />
            <Grid ColumnDefinitions="*,64" ColumnSpacing="12">
              <Slider Minimum="0.1" Maximum="10" Value="{Binding Beta}" />
              <TextBlock Grid.Column="1"
                         VerticalAlignment="Center"
                         HorizontalAlignment="Right"
                         Text="{Binding Beta, StringFormat={}{0:F1}}" />
            </Grid>
          </StackPanel>

          <StackPanel Spacing="6">
            <TextBlock Classes="field-label" Text="Evaporation rate" />
            <Grid ColumnDefinitions="*,64" ColumnSpacing="12">
              <Slider Minimum="0.1" Maximum="0.99" Value="{Binding EvaporationRate}" />
              <TextBlock Grid.Column="1"
                         VerticalAlignment="Center"
                         HorizontalAlignment="Right"
                         Text="{Binding EvaporationRate, StringFormat={}{0:F2}}" />
            </Grid>
          </StackPanel>

          <StackPanel Spacing="6">
            <TextBlock Classes="field-label" Text="Q" />
            <Grid ColumnDefinitions="*,80" ColumnSpacing="12">
              <Slider Minimum="0.1" Maximum="10000" Value="{Binding Q}" />
              <TextBlock Grid.Column="1"
                         VerticalAlignment="Center"
                         HorizontalAlignment="Right"
                         Text="{Binding Q, StringFormat={}{0:F0}}" />
            </Grid>
          </StackPanel>

          <StackPanel Spacing="6">
            <TextBlock Classes="field-label" Text="Initial pheromone" />
            <Grid ColumnDefinitions="*,80" ColumnSpacing="12">
              <Slider Minimum="0.01" Maximum="100" Value="{Binding InitialPheromone}" />
              <TextBlock Grid.Column="1"
                         VerticalAlignment="Center"
                         HorizontalAlignment="Right"
                         Text="{Binding InitialPheromone, StringFormat={}{0:F2}}" />
            </Grid>
          </StackPanel>

          <StackPanel Spacing="6" IsVisible="{Binding UseEliteAnts}">
            <TextBlock Classes="field-label" Text="Коэффициент элитного усиления" />
            <NumericUpDown Minimum="1"
                           Maximum="10"
                           Increment="1"
                           Value="{Binding EliteAntCount}" />
          </StackPanel>
        </StackPanel>
      </Border>

      <StackPanel Orientation="Horizontal"
                  HorizontalAlignment="Right"
                  Spacing="12">
        <Button Classes="action"
                Content="Сбросить"
                Command="{Binding ResetAdvancedSettingsCommand}" />

        <Button Classes="primary-action"
                Content="Закрыть"
                Click="CloseClick" />
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</Window>