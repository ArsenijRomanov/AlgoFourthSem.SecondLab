<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="TSP.Avalonia.App">
  <Application.Styles>
    <FluentTheme />
    <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml" />

    <Style Selector="Window">
      <Setter Property="Background" Value="#0D1117" />
    </Style>

    <Style Selector="Border.card">
      <Setter Property="Background" Value="#161B22" />
      <Setter Property="CornerRadius" Value="18" />
      <Setter Property="Padding" Value="16" />
      <Setter Property="Margin" Value="0,0,0,14" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="#263041" />
      <Setter Property="BoxShadow" Value="0 14 30 0 #22000000" />
    </Style>

    <Style Selector="Border.surface-card">
      <Setter Property="Background" Value="#10161F" />
      <Setter Property="CornerRadius" Value="16" />
      <Setter Property="Padding" Value="12" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="#223047" />
    </Style>

    <Style Selector="TextBlock.panel-title">
      <Setter Property="FontSize" Value="18" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Margin" Value="0,0,0,10" />
    </Style>

    <Style Selector="TextBlock.section-title">
      <Setter Property="FontSize" Value="15" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style Selector="TextBlock.field-label">
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#D6E2F2" />
      <Setter Property="Margin" Value="0,0,0,6" />
    </Style>

    <Style Selector="TextBlock.muted">
      <Setter Property="Foreground" Value="#8B9AB2" />
    </Style>

    <Style Selector="Button.action">
      <Setter Property="MinWidth" Value="120" />
      <Setter Property="Padding" Value="14,9" />
      <Setter Property="CornerRadius" Value="12" />
    </Style>

    <Style Selector="Button.primary-action">
      <Setter Property="Background" Value="#2F81F7" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderBrush" Value="#2F81F7" />
      <Setter Property="MinWidth" Value="126" />
      <Setter Property="Padding" Value="14,9" />
      <Setter Property="CornerRadius" Value="12" />
    </Style>

    <Style Selector="ToggleButton.toolbar-toggle">
      <Setter Property="Padding" Value="12,8" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="Margin" Value="0,0,8,0" />
    </Style>

    <Style Selector="Border.metric-pill">
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="CornerRadius" Value="999" />
      <Setter Property="Background" Value="#1C2533" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="#2C3B52" />
    </Style>

    <Style Selector="TextBlock.metric-value">
      <Setter Property="FontSize" Value="20" />
      <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <Style Selector="Expander.bottom-panel">
      <Setter Property="Margin" Value="0,12,0,0" />
      <Setter Property="Padding" Value="0" />
    </Style>

    <Style Selector="DataGrid">
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="RowBackground" Value="#111821" />
    </Style>
  </Application.Styles>
</Application>
